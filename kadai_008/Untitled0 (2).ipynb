        "import random\n",
        "var = random.randint(0, 1000000)\n",
        "multiple_3 = var % 3\n",
        "multiple_5 = var % 5\n",
        "multiple_15 = var % 15\n",
        "if multiple_15 == 0:\n",
        "  print(\"FizzBuzz\")\n",
        "elif multiple_5 == 0:\n",
        "  print(\"Buzz\")\n",
        "elif multiple_3 == 0:\n",
        "  print(\"Fizz\")\n",
        "else:\n",
        "  print(var)"
      ],
